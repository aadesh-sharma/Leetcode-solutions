    public static void bfs(List<Integer>[] adj, int src) {
        Queue<Integer> q = new LinkedList<>();
        int V = adj.length;
        boolean[] visited = new boolean[V];
        List<Integer>res = new LinkedList<>();

        q.add(src);
        res.add(src);
        visited[src] = true;

        while(!q.isEmpty()) {
            int size = q.size();
            int node = q.poll();
            for(int i=0;i<size;i++){
                for(int child:  adj[node]) {
                    if(!visited[child]) {
                        visited[child] = true;
                        q.add(child);
                        res.add(child);
                    }
                }
            }
        }

        for(int x: res) {
            System.out.print(x + " ");
        }


    }

